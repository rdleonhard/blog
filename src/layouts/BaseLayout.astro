---
import { SITE } from "../lib/site";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = SITE.title,
  description = SITE.description,
} = Astro.props;

const pageTitle = title === SITE.title ? title : `${title} | ${SITE.title}`;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const basePath = import.meta.env.BASE_URL;
const rssUrl = new URL(`${basePath}rss.xml`, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="author" content={SITE.author} />
    <meta name="theme-color" content="#070812" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" type="application/rss+xml" title={`${SITE.title} RSS`} href={rssUrl} />
    <title>{pageTitle}</title>
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta name="twitter:card" content="summary_large_image" />
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href={basePath}>
        <span class="brand-mark">PS</span>
        <span>{SITE.title}</span>
      </a>
      <nav aria-label="Primary navigation">
        <a href={basePath}>Home</a>
        <a href={`${basePath}posts/`}>Posts</a>
        <a href={`${basePath}rss.xml`}>RSS</a>
        <a href={SITE.repo}>Source</a>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <p>{SITE.signal} Published as static files before everything becomes a stream.</p>
      <div class="footer-links">
        <a href={`${basePath}rss.xml`}>RSS</a>
        <a href={`${basePath}sitemap.xml`}>Sitemap</a>
        <a href={SITE.repo}>Source</a>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: dark;
    --bg: #070812;
    --bg-elevated: #101322;
    --ink: #edf7ff;
    --muted: #94a3b8;
    --line: rgba(125, 249, 255, 0.2);
    --accent: #7df9ff;
    --accent-dark: #ff4fd8;
    --warning: #f8f871;
    --shadow: 0 24px 90px rgba(0, 0, 0, 0.42);
    --serif: "Iowan Old Style", "Palatino Linotype", Palatino, Georgia, serif;
    --sans: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    --mono: "SFMono-Regular", Consolas, "Liberation Mono", monospace;
  }

  * {
    box-sizing: border-box;
  }

  html {
    background: var(--bg);
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    min-height: 100vh;
    color: var(--ink);
    background:
      linear-gradient(rgba(125, 249, 255, 0.035) 1px, transparent 1px),
      linear-gradient(90deg, rgba(125, 249, 255, 0.035) 1px, transparent 1px),
      radial-gradient(circle at 18% 10%, rgba(255, 79, 216, 0.2), transparent 30rem),
      radial-gradient(circle at 82% 18%, rgba(125, 249, 255, 0.16), transparent 28rem),
      linear-gradient(135deg, #070812 0%, #101322 52%, #070812 100%);
    background-size:
      48px 48px,
      48px 48px,
      auto,
      auto,
      auto;
    font-family: var(--sans);
    line-height: 1.6;
    text-rendering: optimizeLegibility;
  }

  body::before {
    position: fixed;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    content: "";
    background: linear-gradient(rgba(237, 247, 255, 0.04) 50%, rgba(7, 8, 18, 0.08) 50%);
    background-size: 100% 4px;
    mix-blend-mode: screen;
  }

  a {
    color: inherit;
    text-decoration-color: rgba(125, 249, 255, 0.45);
    text-decoration-thickness: 0.08em;
    text-underline-offset: 0.18em;
  }

  a:hover {
    color: var(--accent);
    text-decoration-color: currentColor;
  }

  a:focus-visible {
    outline: 3px solid rgba(125, 249, 255, 0.42);
    outline-offset: 4px;
    border-radius: 6px;
  }

  img {
    display: block;
    max-width: 100%;
  }

  main {
    width: min(1120px, calc(100% - 32px));
    margin: 0 auto;
  }

  .site-header,
  .site-footer {
    width: min(1120px, calc(100% - 32px));
    margin: 0 auto;
  }

  .site-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding: 28px 0;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    color: var(--ink);
    font-size: 0.88rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-decoration: none;
    text-transform: uppercase;
  }

  .brand-mark {
    display: grid;
    width: 42px;
    height: 42px;
    place-items: center;
    border: 1px solid var(--accent);
    border-radius: 12px;
    color: var(--accent);
    font-family: var(--mono);
    font-size: 0.9rem;
    letter-spacing: 0.04em;
    box-shadow: 0 0 28px rgba(125, 249, 255, 0.25);
  }

  nav {
    display: flex;
    align-items: center;
    gap: 18px;
    color: var(--muted);
    font-size: 0.92rem;
    font-weight: 650;
  }

  nav a {
    text-decoration: none;
  }

  .site-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    padding: 64px 0 40px;
    border-top: 1px solid var(--line);
    color: var(--muted);
    font-size: 0.95rem;
  }

  .site-footer p {
    margin: 0;
  }

  .footer-links {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    font-weight: 700;
  }

  .footer-links a {
    text-decoration: none;
  }

  .eyebrow {
    color: var(--accent);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.18em;
    font-family: var(--mono);
    text-transform: uppercase;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 0 20px;
    border: 1px solid var(--ink);
    border-radius: 999px;
    background: var(--ink);
    color: var(--bg);
    font-weight: 750;
    text-decoration: none;
    transition:
      transform 160ms ease,
      box-shadow 160ms ease,
      background 160ms ease;
  }

  .button:hover {
    transform: translateY(-2px);
    background: var(--accent);
    color: var(--bg);
    box-shadow: 0 0 28px rgba(125, 249, 255, 0.34);
  }

  .button.secondary {
    background: transparent;
    color: var(--ink);
  }

  .button.secondary:hover {
    background: rgba(125, 249, 255, 0.1);
    color: var(--accent);
  }

  .post-card {
    display: grid;
    gap: 16px;
    padding: 28px;
    border: 1px solid var(--line);
    border-radius: 28px;
    background: rgba(16, 19, 34, 0.76);
    box-shadow: 0 16px 56px rgba(0, 0, 0, 0.22);
    text-decoration: none;
    transition:
      transform 160ms ease,
      border-color 160ms ease,
      box-shadow 160ms ease;
  }

  .post-card:hover {
    transform: translateY(-3px);
    border-color: rgba(125, 249, 255, 0.48);
    box-shadow: var(--shadow);
    color: var(--ink);
  }

  .post-card h2,
  .post-card h3 {
    margin: 0;
    font-family: var(--serif);
    font-size: clamp(1.5rem, 2vw, 2.15rem);
    line-height: 1.12;
    letter-spacing: -0.03em;
  }

  .post-card p {
    margin: 0;
    color: var(--muted);
  }

  .post-meta,
  .tag-list {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 10px;
    color: var(--muted);
    font-size: 0.86rem;
  }

  .tag {
    border: 1px solid rgba(125, 249, 255, 0.32);
    border-radius: 999px;
    padding: 4px 10px;
    color: var(--accent);
    background: rgba(125, 249, 255, 0.08);
    font-size: 0.78rem;
    font-weight: 750;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .prose {
    max-width: 740px;
    margin: 0 auto;
    font-family: var(--serif);
    font-size: clamp(1.13rem, 1.8vw, 1.28rem);
    line-height: 1.78;
  }

  .prose :where(h2, h3) {
    margin-top: 2.1em;
    margin-bottom: 0.45em;
    color: var(--ink);
    font-family: var(--sans);
    line-height: 1.2;
    letter-spacing: -0.03em;
  }

  .prose h2 {
    font-size: clamp(1.6rem, 2.5vw, 2.1rem);
  }

  .prose h3 {
    font-size: clamp(1.25rem, 2vw, 1.55rem);
  }

  .prose p {
    margin: 1.15em 0;
  }

  .prose a {
    color: var(--accent);
    font-weight: 650;
  }

  .prose :where(ul, ol) {
    padding-left: 1.35rem;
  }

  .prose li + li {
    margin-top: 0.35rem;
  }

  .prose blockquote {
    margin: 2rem 0;
    padding-left: 1.4rem;
    border-left: 3px solid var(--accent-dark);
    color: var(--ink);
    font-style: italic;
  }

  @media (max-width: 720px) {
    .site-header {
      align-items: flex-start;
      flex-direction: column;
    }

    .site-footer {
      align-items: flex-start;
      flex-direction: column;
    }

    nav {
      width: 100%;
      justify-content: space-between;
    }

    .brand {
      font-size: 0.75rem;
    }
  }
</style>
