---
import { getCollection } from "astro:content";
import { SITE } from "../lib/site";
import BaseLayout from "../layouts/BaseLayout.astro";

const posts = (await getCollection("posts", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf(),
);

const featuredPost = posts[0];
const remainingPosts = posts.slice(1, 4);
const basePath = import.meta.env.BASE_URL;
const formatDate = (date: Date) =>
  new Intl.DateTimeFormat("en", {
    month: "long",
    day: "numeric",
    year: "numeric",
  }).format(date);
---

<BaseLayout>
  <section class="hero">
    <div class="hero-copy">
      <p class="eyebrow">Personal dispatches</p>
      <h1>Notes from a life with room for curiosity.</h1>
      <p>
        A refined home for essays, observations, and digressions that are intentionally not about work,
        but still made with the same care clients notice.
      </p>
      <div class="hero-actions">
        <a class="button" href={`${basePath}posts/`}>Read the latest</a>
        <a class="button secondary" href={SITE.repo}>View the source</a>
      </div>
    </div>
    <aside class="hero-panel" aria-label="About this blog">
      <p class="eyebrow">Editor's note</p>
      <p>
        This site is built as a static publication: fast, portable, and quietly polished. New writing is
        published through GitHub and delivered by GitHub Pages.
      </p>
    </aside>
  </section>

  {
    featuredPost && (
      <section class="featured" aria-labelledby="featured-title">
        <div>
          <p class="eyebrow">Featured essay</p>
          <h2 id="featured-title">{featuredPost.data.title}</h2>
          <p>{featuredPost.data.description}</p>
        </div>
        <a class="post-card featured-card" href={`${basePath}posts/${featuredPost.id}/`}>
          <span class="post-meta">{formatDate(featuredPost.data.publishDate)}</span>
          <span class="read-link">Read essay</span>
        </a>
      </section>
    )
  }

  <section class="post-grid" aria-labelledby="recent-title">
    <div class="section-heading">
      <p class="eyebrow">Recent writing</p>
      <h2 id="recent-title">A few pieces to begin with.</h2>
    </div>
    <div class="cards">
      {
        remainingPosts.map((post) => (
          <a class="post-card" href={`${basePath}posts/${post.id}/`}>
            <span class="post-meta">{formatDate(post.data.publishDate)}</span>
            <h3>{post.data.title}</h3>
            <p>{post.data.description}</p>
            <div class="tag-list">
              {post.data.tags.map((tag) => (
                <span class="tag">{tag}</span>
              ))}
            </div>
          </a>
        ))
      }
    </div>
  </section>

  <section class="craft-notes" aria-labelledby="craft-title">
    <p class="eyebrow">Built to last</p>
    <h2 id="craft-title">Static, fast, and easy to keep publishing.</h2>
    <div class="craft-grid">
      <p>Posts are plain Markdown files, so the writing stays portable and versioned.</p>
      <p>GitHub Actions publishes the site to Pages after each push to `main`.</p>
      <p>RSS, sitemap, and robots metadata make the site easier to follow and discover.</p>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 360px;
    gap: clamp(28px, 5vw, 72px);
    align-items: end;
    min-height: 68vh;
    padding: clamp(56px, 9vw, 112px) 0 72px;
  }

  .hero-copy h1 {
    max-width: 820px;
    margin: 14px 0 24px;
    font-family: var(--serif);
    font-size: clamp(4rem, 10vw, 9.6rem);
    font-weight: 500;
    line-height: 0.9;
    letter-spacing: -0.075em;
  }

  .hero-copy > p:not(.eyebrow) {
    max-width: 660px;
    margin: 0;
    color: var(--muted);
    font-size: clamp(1.1rem, 2vw, 1.35rem);
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 34px;
  }

  .hero-panel {
    padding: 30px;
    border: 1px solid var(--line);
    border-radius: 32px;
    background: rgba(255, 250, 241, 0.76);
    box-shadow: var(--shadow);
  }

  .hero-panel p:last-child {
    margin-bottom: 0;
    color: var(--muted);
  }

  .featured {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 320px;
    gap: 28px;
    align-items: stretch;
    padding: 44px;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }

  .featured h2,
  .section-heading h2 {
    margin: 10px 0 14px;
    font-family: var(--serif);
    font-size: clamp(2.1rem, 5vw, 4.5rem);
    font-weight: 500;
    line-height: 1;
    letter-spacing: -0.055em;
  }

  .featured p:not(.eyebrow),
  .section-heading {
    color: var(--muted);
  }

  .featured-card {
    align-content: space-between;
    min-height: 220px;
  }

  .read-link {
    color: var(--accent-dark);
    font-weight: 800;
  }

  .post-grid {
    padding: 72px 0 24px;
  }

  .section-heading {
    max-width: 650px;
    margin-bottom: 30px;
  }

  .cards {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
  }

  .craft-notes {
    margin-top: 56px;
    padding: 34px;
    border: 1px solid var(--line);
    border-radius: 32px;
    background: rgba(29, 26, 22, 0.04);
  }

  .craft-notes h2 {
    max-width: 740px;
    margin: 10px 0 24px;
    font-family: var(--serif);
    font-size: clamp(2rem, 4vw, 3.8rem);
    font-weight: 500;
    line-height: 1;
    letter-spacing: -0.055em;
  }

  .craft-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
    color: var(--muted);
  }

  .craft-grid p {
    margin: 0;
  }

  @media (max-width: 900px) {
    .hero,
    .featured {
      grid-template-columns: 1fr;
    }

    .cards,
    .craft-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .featured {
      padding: 32px 0;
    }
  }
</style>
