---
import { getCollection } from "astro:content";
import { sitePath } from "../lib/paths";
import { SITE } from "../lib/site";
import BaseLayout from "../layouts/BaseLayout.astro";

const posts = (await getCollection("posts", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf(),
);

const featuredPost = posts[0];
const remainingPosts = posts.slice(1, 4);
const formatDate = (date: Date) =>
  new Intl.DateTimeFormat("en", {
    month: "long",
    day: "numeric",
    year: "numeric",
  }).format(date);
---

<BaseLayout>
  <section class="hero">
    <div class="hero-copy">
      <p class="eyebrow">Pre-singularity log</p>
      <h1>Human notes from the machine threshold.</h1>
      <p>
        Personal reflections from someone living through the AI transition: part journal, part field
        recording, part neon-lit archive of what still feels human.
      </p>
      <p class="hero-author">Written by {SITE.author}</p>
      <div class="hero-actions">
        <a class="button" href={sitePath("posts/")}>Read the signal</a>
        <a class="button secondary" href={SITE.repo}>View the source</a>
      </div>
    </div>
    <aside class="hero-panel" aria-label="About this blog">
      <p class="eyebrow">Transmission</p>
      <p>
        Not a tech blog. Not a portfolio. A personal record from the years when the interface between
        human intention and machine intelligence started to glow.
      </p>
    </aside>
  </section>

  {
    featuredPost && (
      <section class="featured" aria-labelledby="featured-title">
        <div>
          <p class="eyebrow">Primary signal</p>
          <h2 id="featured-title">{featuredPost.data.title}</h2>
          <p>{featuredPost.data.description}</p>
        </div>
        <a class="post-card featured-card" href={sitePath(`posts/${featuredPost.id}/`)}>
          <span class="post-meta">{formatDate(featuredPost.data.publishDate)}</span>
          <span class="read-link">Open transmission</span>
        </a>
      </section>
    )
  }

  <section class="post-grid" aria-labelledby="recent-title">
    <div class="section-heading">
      <p class="eyebrow">Recent transmissions</p>
      <h2 id="recent-title">Dispatches before the curve goes vertical.</h2>
    </div>
    <div class="cards">
      {
        remainingPosts.map((post) => (
          <a class="post-card" href={sitePath(`posts/${post.id}/`)}>
            <span class="post-meta">{formatDate(post.data.publishDate)}</span>
            <h3>{post.data.title}</h3>
            <p>{post.data.description}</p>
            <div class="tag-list">
              {post.data.tags.map((tag) => (
                <span class="tag">{tag}</span>
              ))}
            </div>
          </a>
        ))
      }
    </div>
  </section>

  <section class="craft-notes" aria-labelledby="craft-title">
    <p class="eyebrow">Signal architecture</p>
    <h2 id="craft-title">Static pages for unstable times.</h2>
    <div class="craft-grid">
      <p>Plain Markdown keeps the record portable while platforms mutate around it.</p>
      <p>GitHub Actions turns each commit into a fresh public transmission.</p>
      <p>RSS, sitemap, and robots metadata keep the signal discoverable outside the feed.</p>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 360px;
    gap: clamp(28px, 5vw, 72px);
    align-items: end;
    min-height: 68vh;
    padding: clamp(56px, 9vw, 112px) 0 72px;
  }

  .hero-copy h1 {
    max-width: 820px;
    margin: 14px 0 24px;
    font-family: var(--serif);
    font-size: clamp(4rem, 10vw, 9.6rem);
    font-weight: 500;
    line-height: 0.9;
    letter-spacing: -0.075em;
  }

  .hero-copy > p:not(.eyebrow) {
    max-width: 660px;
    margin: 0;
    color: var(--muted);
    font-size: clamp(1.1rem, 2vw, 1.35rem);
  }

  .hero-copy .hero-author {
    margin-top: 18px;
    color: var(--accent);
    font-family: var(--mono);
    font-size: 0.86rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 34px;
  }

  .hero-panel {
    padding: 30px;
    border: 1px solid var(--line);
    border-radius: 32px;
    background:
      linear-gradient(135deg, rgba(125, 249, 255, 0.1), rgba(255, 79, 216, 0.08)),
      rgba(16, 19, 34, 0.78);
    box-shadow: var(--shadow);
  }

  .hero-panel p:last-child {
    margin-bottom: 0;
    color: var(--muted);
  }

  .featured {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 320px;
    gap: 28px;
    align-items: stretch;
    padding: 44px;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }

  .featured h2,
  .section-heading h2 {
    margin: 10px 0 14px;
    font-family: var(--serif);
    font-size: clamp(2.1rem, 5vw, 4.5rem);
    font-weight: 500;
    line-height: 1;
    letter-spacing: -0.055em;
  }

  .featured p:not(.eyebrow),
  .section-heading {
    color: var(--muted);
  }

  .featured-card {
    align-content: space-between;
    min-height: 220px;
  }

  .read-link {
    color: var(--accent-dark);
    font-weight: 800;
  }

  .post-grid {
    padding: 72px 0 24px;
  }

  .section-heading {
    max-width: 650px;
    margin-bottom: 30px;
  }

  .cards {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
  }

  .craft-notes {
    margin-top: 56px;
    padding: 34px;
    border: 1px solid var(--line);
    border-radius: 32px;
    background: rgba(16, 19, 34, 0.72);
  }

  .craft-notes h2 {
    max-width: 740px;
    margin: 10px 0 24px;
    font-family: var(--serif);
    font-size: clamp(2rem, 4vw, 3.8rem);
    font-weight: 500;
    line-height: 1;
    letter-spacing: -0.055em;
  }

  .craft-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
    color: var(--muted);
  }

  .craft-grid p {
    margin: 0;
  }

  @media (max-width: 900px) {
    .hero,
    .featured {
      grid-template-columns: 1fr;
    }

    .cards,
    .craft-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .featured {
      padding: 32px 0;
    }
  }
</style>
